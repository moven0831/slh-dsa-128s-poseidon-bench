{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm build:wasm && pnpm copy:assets && vite",
    "build": "pnpm build:wasm && pnpm copy:assets && vite build && tsc --noEmit",
    "build:wasm": "bash scripts/build-wasm.sh",
    "copy:assets": "bash scripts/copy-assets.sh",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:real": "E2E_MODE=real pnpm build && E2E_MODE=real playwright test --grep @real",
    "lint": "tsc --noEmit && bash scripts/check-no-pin-leak.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "fake-indexeddb": "^6.2.5",
    "typescript": "~6.0.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "nanostores": "^1.3.0"
  }
}
